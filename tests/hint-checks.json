{
  "tests": [
    {"section": "=== Contradictions: counting ==="},

    {
      "name": "CountAnswer contradiction: count exceeds value",
      "description": "count_answer A=0 but 2 A's already found",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["C", "A", "A", ""],
      "expect": "!1"
    },
    {
      "name": "CountAnswer contradiction: count+remaining < value",
      "description": "count_answer A=2 but all others answered non-A, 0 remaining",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "B", "C", "D"],
      "expect": "!1"
    },
    {
      "name": "CountVowel contradiction: count exceeds value",
      "description": "count_vowel=0 but A and E already found",
      "puzzle": {"q": [
        {"r": {"t": "count_vowel_answers"}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["C", "A", "E", ""],
      "expect": "!1"
    },
    {
      "name": "CountConsonant contradiction: count+remaining too low",
      "description": "count_consonant=3 but only 1 consonant found, 1 remaining → 1+1=2 < 3",
      "puzzle": {"q": [
        {"r": {"t": "count_consonant_answers"}, "o": [2, 3, 0, 1, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["D", "B", "A", "A"],
      "expect": "!1"
    },
    {
      "name": "CountAnswerBefore contradiction: count exceeds value in range",
      "description": "count_answer_before A <Q3 = 0, but Q1=A → count=1 > 0",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "count_answer_before", "a": 0, "q": 2}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "", "C", ""],
      "expect": "!3"
    },

