      "state": ["", "A", "", "A"],
      "expect": "!2"
    },
    {
      "name": "FirstWith None contradiction: a match exists",
      "puzzle": {"q": [
        {"r": {"t": "first_with_answer", "a": 0}, "o": [1, 2, null, 0, 3]},
