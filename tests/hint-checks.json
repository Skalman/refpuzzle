      "state": ["", "A"],
      "expect": "1B"
    },
    {
      "name": "Forced: LetterDist only 1 option matches distance",
      "puzzle": {"q": [
        {"r": {"t": "letter_distance", "q": 1}, "o": [0, 1, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["abde", "C"],
      "expect": "1C"
    },

