{
  "name": "refpuzzle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm lint && vite build",
    "preview": "vite preview",
    "lint": "oxlint --tsconfig tsconfig.app.json --type-aware --type-check src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "generate": "node --experimental-strip-types scripts/generate-puzzles.ts",
    "test": "node --experimental-strip-types scripts/test.ts",
    "bench": "vite build --config scripts/vite-bench.config.ts && node dist-scripts/bench.js",
    "bench:profile": "vite build --config scripts/vite-bench.config.ts && node --prof dist-scripts/bench.js && node --prof-process isolate-*.log && rm isolate-*.log"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "preact": "^10.28.4",
    "preact-iso": "^2.11.1",
    "tinykeys": "^3.0.0",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.3",
    "@types/node": "^24.12.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.21.1",
    "vite": "^8.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
