{
  "name": "refpuzzle",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm lint && vite build",
    "preview": "vite preview",
    "lint": "oxlint --type-aware --type-check src/ scripts/",
    "fmt": "oxfmt --write src/ tests/",
    "fmt:check": "oxfmt --check src/ tests/",
    "gen": "node scripts/gen.ts",
    "check": "node scripts/check.ts",
    "check-diff": "node scripts/check-diff.ts",
    "trace-diff": "node scripts/trace-diff.ts",
    "test": "node scripts/test.ts",
    "test:all": "node scripts/test.ts --all",
    "bench": "vite build --config scripts/vite-bench.config.ts && node dist-scripts/bench.js",
    "bench:profile": "vite build --config scripts/vite-bench.config.ts && node --prof dist-scripts/bench.js && node --prof-process isolate-*.log && rm isolate-*.log"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "preact": "^10.29.1",
    "preact-iso": "^2.12.0",
    "tinykeys": "^3.0.0",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "vite": "^8.0.10"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
