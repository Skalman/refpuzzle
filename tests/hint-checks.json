    {"section": "=== Eliminations: counting ==="},

    {
      "name": "CountAnswer elimination: count exceeds option value",
      "description": "Q1=count_answer A, option C claims 0. Q2=A, Q3=A → count=2 > 0.",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [3, 2, 0, 1, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "A", "A", ""],
      "expect": "1c"
