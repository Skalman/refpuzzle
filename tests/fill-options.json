{
  "_doc": "expectedCorrect[qi] is the hand-computed value stored at the correct option for question qi. Use null for AnswerIsSelf/NoOtherHasAnswer/TrueStmt (no numeric value) or to intentionally skip a check.",
  "tests": [
    {
      "section": "=== mixed types, oc=5 ==="
    },
    {
      "name": "n=5 count + identity + positional + vowel",
      "n": 5,
      "oc": 5,
      "types": [
        {
          "t": "CountAnswer",
          "a": 0
        },
        {
          "t": "AnswerIsSelf"
        },
        {
          "t": "FirstWith",
          "a": 0
        },
        {
          "t": "CountVowel"
        },
        {
          "t": "LastWith",
          "a": 3
        }
      ],
      "solution": "ABACD",
      "expectedCorrect": [2, null, 0, 2, 4]
    },
    {
      "name": "n=6 positional + AnswerOf + CountAnswer{Before,After}",
      "n": 6,
      "oc": 5,
      "types": [
        {
          "t": "FirstWith",
          "a": 0
        },
        {
          "t": "AnswerOf",
          "q": 0
        },
        {
          "t": "CountAnswer",
          "a": 0
        },
        {
          "t": "CountAnswerAfter",
          "a": 0,
          "q": 0
        },
        {
          "t": "CountAnswerBefore",
          "a": 0,
          "q": 4
        },
        {
          "t": "LastWith",
          "a": 0
        }
      ],
      "solution": "AAABCD",
      "expectedCorrect": [0, 0, 3, 2, 3, 2]
    },
    {
      "name": "n=5 LeastCommon / MostCommon (unique extremes)",
      "n": 5,
      "oc": 5,
      "types": [
        {
          "t": "LeastCommon"
        },
        {
          "t": "MostCommon"
        },
        {
          "t": "AnswerIsSelf"
        },
        {
          "t": "AnswerIsSelf"
        },
        {
          "t": "AnswerIsSelf"
        }
      ],
      "solution": "BABCD",
      "expectedCorrect": [4, 1, null, null, null]
    },
    {
