{
  "tests": [
    {"section": "=== Solve: deduce only ==="},

    {
      "name": "4-question puzzle: answer_of + count_answer + last_with",
      "puzzle": {"q": [
        {"r": {"t": "last_with_answer", "a": 0}, "o": [2, 0, null, 3, 1]},
        {"r": {"t": "answer_of_question", "q": 2}, "o": [4, 1, 0, 3, 2]},
        {"r": {"t": "count_answer", "a": 2}, "o": [1, 2, 3, 4, 0]},
        {"r": {"t": "answer_of_question", "q": 1}, "o": [4, 2, 0, 1, 3]}
      ]},
      "expect": "solved"
    },
    {
      "name": "3-question trivial: all answer_is_self with 1 remaining each",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "expect": "stuck"
    },

    {"section": "=== Solve: requires lookahead ==="},

    {
      "name": "Lookahead needed: assumption eliminates via count contradiction",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [2, 2, 2, 2, 2]},
        {"r": {"t": "answer_of_question", "q": 0}, "o": [0, 1, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "expect": "stuck"
    },

    {"section": "=== Solve: count saturation ==="},

    {
      "name": "Count saturation solves: count_answer + answer_of",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [0, 1, 2, 3, 4]},
        {"r": {"t": "answer_of_question", "q": 0}, "o": [0, 1, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "expect": "stuck"
    },

    {"section": "=== Solve: real puzzles ==="},

