      "name": "4-question puzzle: answer_of + count_answer + last_with",
      "puzzle": {
        "q": [
          { "t": { "t": "LastWith", "a": 0 }, "o": [2, 0, null, 3, 1] },
          { "t": { "t": "AnswerOf", "q": 2 }, "o": [4, 1, 0, 3, 2] },
          { "t": { "t": "CountAnswer", "a": 2 }, "o": [1, 2, 3, 4, 0] },
          { "t": { "t": "AnswerOf", "q": 1 }, "o": [4, 2, 0, 1, 3] }
        ]
      },
      "expect": "solved"
    },
    {
      "name": "3-question trivial: all answer_is_self with 1 remaining each",
      "puzzle": {
        "q": [
          { "t": { "t": "AnswerIsSelf" }, "o": [null, null, null, null, null] },
          { "t": { "t": "AnswerIsSelf" }, "o": [null, null, null, null, null] },
          { "t": { "t": "AnswerIsSelf" }, "o": [null, null, null, null, null] }
        ]
      },
      "expect": "stuck"
    },
