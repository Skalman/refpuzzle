      "puzzle": {"q":[{"o":[7,5,1,3,0],"r":{"a":4,"q":8,"t":"closest_before"}},{"c":[{"a":2,"t":"count_answer","v":1},{"a":3,"q":2,"t":"count_answer_after","v":5},{"a":4,"q":6,"t":"count_answer_before","v":1},{"t":"count_vowel_answers","v":1},{"t":"count_vowel_answers","v":4}],"r":{"t":"only_true_statement"}},{"o":[2,0,1,3,4],"r":{"q":5,"t":"letter_distance"}},{"o":[8,null,2,0,10],"r":{"a":0,"t":"only_odd_with_answer"}},{"o":[8,0,10,null,4],"r":{"a":4,"t":"only_odd_with_answer"}},{"o":[5,11,4,1,0],"r":{"a":1,"t":"first_with_answer"}},{"o":[6,null,3,5,0],"r":{"t":"consecutive_identical"}},{"o":[1,3,0,4,2],"r":{"q":9,"t":"answer_of_question"}},{"o":[0,7,5,9,1],"r":{"t":"count_consonant_answers"}},{"o":[6,9,3,0,11],"r":{"t":"count_vowel_answers"}},{"o":[2,0,3,1,4],"r":{"q":7,"t":"answer_of_question"}},{"o":[null,4,2,6,0],"r":{"a":3,"q":8,"t":"closest_before"}}]},
