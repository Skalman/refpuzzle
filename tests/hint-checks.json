    {
      "name": "LetterDist elimination: distance doesn't match",
      "description": "Q1=letter_dist Q2, Q2=C. Option A: |A-C|=2, value=3. 2≠3 → eliminate.",
      "puzzle": {"q": [
        {"r": {"t": "letter_distance", "q": 1}, "o": [3, 1, 0, 1, 2]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "C", ""],
      "expect": "1a"
    }
  ]
}
