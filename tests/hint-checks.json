      "state": ["B", "A", "", ""],
      "expect": "3a"
    },
    {
      "name": "Count saturation: remaining must all match",
      "description": "count_answer A=3, 2 A's found, 1 remaining unanswered → must be A, eliminate non-A",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [4, 3, 2, 1, 0]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["D", "A", "A", ""],
      "expect": "4b"
    },

    {"section": "=== Forced values ==="},

