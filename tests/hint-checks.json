{
  "tests": [
    {"section": "=== Contradictions ==="},

    {
      "name": "CountAnswer contradiction: count exceeds value",
      "description": "Q1=count_answer A, answered C (value=0). But Q2=A and Q3=A → count=2 > 0.",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["C", "A", "A", ""],
      "expect": "!1"
    },
    {
      "name": "CountAnswer contradiction: count+remaining < value",
      "description": "Q1=count_answer A, answered A (value=2). Q2=B, Q3=C, Q4=D → 0 A's, 0 remaining. 0<2.",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "B", "C", "D"],
      "expect": "!1"
    },
    {
      "name": "AnswerOf contradiction: target has different answer",
      "description": "Q1=answer_of Q2, answered A. Option A maps to B. But Q2=C ≠ B.",
      "puzzle": {"q": [
        {"r": {"t": "answer_of_question", "q": 1}, "o": [1, 0, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "C", ""],
      "expect": "!1"
    },
    {
      "name": "LetterDist contradiction: distance doesn't match",
      "description": "Q1=letter_dist Q2, answered A (value=0). Q2=D. |A-D|=3 ≠ 0.",
      "puzzle": {"q": [
        {"r": {"t": "letter_distance", "q": 1}, "o": [0, 1, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "D", ""],
      "expect": "!1"
    },
    {
      "name": "Unique contradiction: answer appears twice",
      "puzzle": {"q": [
        {"r": {"t": "unique_answer"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["B", "B", ""],
      "expect": "!1"
    },
    {
      "name": "FirstWith contradiction: position has wrong answer",
      "description": "Q1=first_with A, answered B (value=1 → Q2). Q2=C ≠ A.",
      "puzzle": {"q": [
        {"r": {"t": "first_with_answer", "a": 0}, "o": [0, 1, null, 2, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["B", "C", ""],
      "expect": "!1"
    },
    {
      "name": "FirstWith contradiction: earlier match exists",
      "description": "Q2=first_with A, answered C (value=2 → Q3). But Q1=A is before Q3.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "first_with_answer", "a": 0}, "o": [0, 1, 2, null, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "C", "", ""],
      "expect": "!2"
    },
    {
      "name": "LastWith contradiction: later match exists",
      "description": "Q2=last_with A, answered A (value=0 → Q1). But Q4=A is after Q1.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "last_with_answer", "a": 0}, "o": [0, null, 2, 3, 1]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "A", "", "A"],
      "expect": "!2"
    },
    {
      "name": "FirstWith None contradiction: match exists so None invalid",
      "description": "Q1=first_with A, answered C (value=null/None). But Q2=A exists.",
      "puzzle": {"q": [
        {"r": {"t": "first_with_answer", "a": 0}, "o": [1, 2, null, 0, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["C", "A", ""],
      "expect": "!1"
    },
    {
      "name": "SameAs contradiction: target has different answer",
      "description": "Q1=same_as, answered D (value=2 → Q3). Q3=B, Q1=D. B≠D.",
      "puzzle": {"q": [
        {"r": {"t": "same_answer_as"}, "o": [null, 1, 2, 2, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["D", "", "B"],
      "expect": "!1"
    },
    {
      "name": "Evaluate fallback: PrevSame wrong when all answered",
      "description": "Q3=prev_same answered B, claims Q1. Q1=A ≠ Q3=B. All answered.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "previous_same_answer"}, "o": [null, 0, 1, null, 2]}
      ]},
      "state": ["A", "C", "B"],
      "expect": "!3"
    },
    {
      "name": "Evaluate fallback: ConsecIdent wrong when all answered",
      "description": "Q4=consec_ident answered A, claims Q1&Q2 pair. Q1=C, Q2=D differ. All answered.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "consecutive_identical"}, "o": [0, 1, null, 2, 3]}
      ]},
      "state": ["C", "D", "E", "A"],
      "expect": "!4"
    },

    {"section": "=== Count saturation ==="},

    {
      "name": "Count saturation: count met, eliminate remaining matches",
      "description": "Q1=count_answer A=1 (answered B). Q2=A. count=1=value. Eliminate A from Q3,Q4.",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [2, 1, 0, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["B", "A", "", ""],
      "expect": "3a"
    },
    {
      "name": "Count saturation: remaining must all match",
      "description": "Q1=count_answer A=3 (answered D). Q2=A, Q3=A. count=2, remaining=1. 2+1=3=value. Q4 must be A.",
      "puzzle": {"q": [
        {"r": {"t": "count_answer", "a": 0}, "o": [4, 3, 2, 3, 0]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["D", "A", "A", ""],
      "expect": "4b"
    },

    {"section": "=== Forced values ==="},

    {
      "name": "Forced: only 1 option remaining",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "abde"],
      "expect": "2C"
    },
    {
      "name": "Forced: AnswerOf forward (target known)",
      "description": "Q1=answer_of Q2. Options map: A→B, B→A, C→C, D→D, E→E. Q2=B. Option A maps to B → Q1=A.",
      "puzzle": {"q": [
        {"r": {"t": "answer_of_question", "q": 1}, "o": [1, 0, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "B"],
      "expect": "1A"
    },
    {
      "name": "Forced: AnswerOf reverse (other AnswerOf references this one)",
      "description": "Q2=answer_of Q1, answered A. Option A maps to C. So Q1=C.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_of_question", "q": 0}, "o": [2, 0, 1, 3, 4]}
      ]},
      "state": ["", "A"],
      "expect": "1C"
    },
    {
      "name": "Forced: LetterDist only 1 valid option",
      "description": "Q1=letter_dist Q2, only C remains. Q2=C. |C-C|=0, option C value=2 → doesn't match. But C is the only option...",
      "puzzle": {"q": [
        {"r": {"t": "letter_distance", "q": 1}, "o": [3, 1, 0, 2, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["bcde", "B"],
      "expect": "1A"
    },

    {"section": "=== Eliminations: positional ==="},

    {
      "name": "FirstWith elimination: position has wrong answer",
      "description": "Q1=first_with A, option B claims Q2. Q2=B ≠ A.",
      "puzzle": {"q": [
        {"r": {"t": "first_with_answer", "a": 0}, "o": [0, 1, null, 2, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "B", "", ""],
      "expect": "1b"
    },
    {
      "name": "FirstWith elimination: answer eliminated from target",
      "description": "Q1=first_with C, option A claims Q2. C eliminated from Q2.",
      "puzzle": {"q": [
        {"r": {"t": "first_with_answer", "a": 2}, "o": [1, 2, null, 0, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "c", "", ""],
      "expect": "1a"
    },
    {
      "name": "FirstWith elimination: earlier match exists",
      "description": "Q2=first_with A, option B claims Q2 (index 1). But Q1=A is before Q2.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "first_with_answer", "a": 0}, "o": [0, 1, 2, 3, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["A", "", "", ""],
      "expect": "2b"
    },
    {
      "name": "FirstWith None elimination: match exists",
      "description": "Q1=first_with A, option C is None. But Q3=A exists.",
      "puzzle": {"q": [
        {"r": {"t": "first_with_answer", "a": 0}, "o": [0, 1, null, 2, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "", "A"],
      "expect": "1c"
    },
    {
      "name": "LastWith elimination: later match exists",
      "description": "Q2=last_with A, option A claims Q1 (index 0). But Q4=A is later.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "last_with_answer", "a": 0}, "o": [0, null, 2, 3, 1]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "", "", "A"],
      "expect": "2a"
    },
    {
      "name": "ClosestAfter elimination: position out of range",
      "description": "Q3=closest_after A (afterIndex=1), option A claims Q1 (index 0). 0 < afterIndex+1=2.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "closest_after", "a": 0, "q": 1}, "o": [0, 1, null, 2, 3]}
      ]},
      "state": ["", "", ""],
      "expect": "3a"
    },

    {"section": "=== Eliminations: AnswerOf ==="},

    {
      "name": "AnswerOf elimination: claimed letter eliminated from target",
      "description": "Q1=answer_of Q2. Option A maps to B. B eliminated from Q2.",
      "puzzle": {"q": [
        {"r": {"t": "answer_of_question", "q": 1}, "o": [1, 0, 2, 3, 4]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "b"],
      "expect": "1a"
    },

    {"section": "=== Eliminations: structural ==="},

    {
      "name": "PrevSame elimination: position after self",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "previous_same_answer"}, "o": [null, 0, 1, null, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "", "", ""],
      "expect": "3e"
    },
    {
      "name": "PrevSame elimination: closer match exists",
      "description": "Q5=prev_same, option B claims Q1. But Q4=B is closer.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "previous_same_answer"}, "o": [null, 0, 2, 3, null]}
      ]},
      "state": ["", "", "", "B", ""],
      "expect": "5b"
    },
    {
      "name": "NextSame elimination: position before self",
      "description": "Q1=next_same, option B claims Q1 (index 0). 0 ≤ qi=0.",
      "puzzle": {"q": [
        {"r": {"t": "next_same_answer"}, "o": [null, 0, null, 1, 2]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "", ""],
      "expect": "1b"
    },
    {
      "name": "NextSame elimination: closer match exists",
      "description": "Q1=next_same, option D claims Q4. But Q2=D is closer.",
      "puzzle": {"q": [
        {"r": {"t": "next_same_answer"}, "o": [null, 1, 2, 3, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "D", "", ""],
      "expect": "1d"
    },
    {
      "name": "OnlySame elimination: self-reference",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "only_same_answer"}, "o": [0, 1, 2, null, 3]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]}
      ]},
      "state": ["", "", "", ""],
      "expect": "2b"
    },
    {
      "name": "ConsecIdent elimination: pair has different answers",
      "description": "Q4=consec_ident, option A claims Q1&Q2 pair. Q1=A, Q2=B differ.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "consecutive_identical"}, "o": [0, 1, null, 2, 3]}
      ]},
      "state": ["A", "B", "", ""],
      "expect": "4a"
    },
    {
      "name": "ConsecIdent None elimination: pair exists",
      "description": "Q3=consec_ident, option B is None. But Q1=A, Q2=A is a pair.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "consecutive_identical"}, "o": [0, null, 1, 2, 3]}
      ]},
      "state": ["A", "A", ""],
      "expect": "3b"
    },
    {
      "name": "OnlyOdd elimination: even position",
      "description": "Q4=only_odd A, option B claims Q2 (index 1, even 1-indexed=2).",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "only_odd_with_answer", "a": 0}, "o": [0, 1, null, 2, 3]}
      ]},
      "state": ["", "", "", ""],
      "expect": "4b"
    },
    {
      "name": "OnlyOdd elimination: target has wrong answer",
      "description": "Q4=only_odd A, option A claims Q1 (index 0, odd). But Q1=B ≠ A.",
      "puzzle": {"q": [
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
        {"r": {"t": "answer_is_self"}, "o": [null, null, null, null, null]},
